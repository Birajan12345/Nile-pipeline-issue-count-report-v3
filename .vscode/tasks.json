{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run NILE Tracker",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["run.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
